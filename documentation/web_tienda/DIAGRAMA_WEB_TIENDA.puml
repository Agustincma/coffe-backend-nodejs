@startuml
' Diagrama ER - Tablas principales para la App Web de la Tienda
left to right direction

entity tiendas {
  *id : UUID
  nombre : string
  qr : string
  direccion : string
  fecha_creacion : timestamp
}
entity usuarios {
  *id : UUID
  nombre : string
  email : string
  password : string
  rol : enum
  fecha_creacion : timestamp
}
entity productos {
  *id : UUID
  nombre : string
  descripcion : string
  precio : decimal
  stock : int
  habilitado : boolean
  tienda_id : UUID
  fecha_creacion : timestamp
}
entity pedidos {
  *id : UUID
  usuario_id : UUID
  tienda_id : UUID
  mesa_id : UUID
  estado : enum
  total : decimal
  fecha : timestamp
  fecha_cancelacion : timestamp
}
entity descuentos {
  *id : UUID
  producto_id : UUID
  categoria : string
  porcentaje : int
  activo : boolean
  fecha_inicio : timestamp
  fecha_fin : timestamp
}
entity archivos {
  *id : UUID
  url : string
  tipo : string
  producto_id : UUID
  tienda_id : UUID
  fecha_subida : timestamp
}
entity mesas {
  *id : UUID
  numero : int
  qr : string
  tienda_id : UUID
}
entity comentarios {
  *id : UUID
  usuario_id : UUID
  producto_id : UUID
  texto : string
  fecha : timestamp
}
entity puntuaciones {
  *id : UUID
  usuario_id : UUID
  producto_id : UUID
  valor : int
}

' Relaciones principales
usuarios --> pedidos : crea
usuarios --> comentarios : comenta
usuarios --> puntuaciones : califica
usuarios --> tiendas : administra

tiendas --> productos : ofrece
productos --> descuentos : tiene
productos --> archivos : tiene
productos --> comentarios : recibe
productos --> puntuaciones : recibe
tiendas --> pedidos : recibe
tiendas --> archivos : almacena
tiendas --> mesas : tiene
mesas --> pedidos : recibe

' Tablas en común con otras apps: usuarios, productos, pedidos, comentarios, puntuaciones
@enduml
