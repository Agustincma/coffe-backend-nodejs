@startuml
' Flujo visual tipo Figma para Web App (Tienda)
left to right direction
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor #333
  FontColor #222
}

rectangle "LoginPage" as LoginPage
rectangle "DashboardPage" as DashboardPage
rectangle "ProductsPage" as ProductsPage
rectangle "ProductDetailPage" as ProductDetailPage
rectangle "ProductForm" as ProductForm
rectangle "StockManagementPage" as StockManagementPage

LoginPage -right-> DashboardPage : Acceso exitoso
DashboardPage -right-> ProductsPage : Productos
ProductsPage -down-> ProductDetailPage : Ver/Editar
ProductDetailPage -right-> ProductForm : Editar/Crear
ProductDetailPage -down-> StockManagementPage : Gestionar stock

@enduml
